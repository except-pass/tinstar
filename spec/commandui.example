import React, {useEffect, useMemo, useRef, useState} from "react";
import { Command, CommandEmpty, CommandGroup, CommandInput, CommandItem, CommandList, CommandSeparator } from "@/components/ui/command";
import { Card, CardContent } from "@/components/ui/card";
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Star, CornerDownLeft, X } from "lucide-react";
import { motion } from "framer-motion";

/**
 * DATA MODEL (backend-friendly)
 * -------------------------------------------
 * - SlashCommandData is the single source of truth that feeds this UI.
 * - Backends can populate it from ~/.claude/commands, project .claude/commands, DB, etc.
 * - The UI never reaches into localStorage except as a convenience to seed/merge prefs.
 */

export type CommandRecord = {
  id: string;                 // stable id (hash of path, name, etc.)
  name: string;               // canonical "/name" (namespaced allowed: "/dev/debug-trace")
  description?: string;       // short summary
  aliases?: string[];         // alternative slash names: ["/trace", "/debug"]
  tags?: string[];            // lightweight facets: ["debug", "grpc", "api"]
  allowedTools?: string[];    // e.g., ["Bash(*)", "Edit", "mcp__influx__query"]
  source?: "project" | "user" | "sdk"; // provenance
  path?: string;              // filesystem path (if applicable)
  version?: string;           // semantic or content hash
  createdAt?: string;         // ISO timestamps (optional)
  updatedAt?: string;
};

export type CommandsIndex = {
  byId: Record<string, CommandRecord>; // id → record
  order: string[];                     // default display order of ids (usually alpha)
};

export type UserPrefs = {
  starred: string[];   // list of command ids the user pinned
  recent: string[];    // MRU list (ids) from this client/user
};

export type SlashCommandData = {
  index: CommandsIndex;
  prefs: UserPrefs;
};

/**
 * PURE HELPERS (unit-testable)
 */
export function parseInput(raw: string): { token: string; args: string; raw: string } {
  const trimmed = raw.trimStart();
  if (!trimmed.startsWith("/")) return { token: "", args: trimmed, raw };
  const spaceIdx = trimmed.indexOf(" ");
  if (spaceIdx === -1) return { token: trimmed, args: "", raw };
  return { token: trimmed.slice(0, spaceIdx), args: trimmed.slice(spaceIdx + 1), raw };
}

export function buildHaystack(c: CommandRecord): string {
  // Lowercased, newline-delimited set of searchable strings
  return [
    c.name.replace(/^\//, ""),
    ...(c.aliases || []).map(a => a.replace(/^\//, "")),
    c.description || "",
    ...(c.tags || [])
  ].join('\n').toLowerCase();
}

export function commandMatches(c: CommandRecord, tokenNorm: string): boolean {
  if (!tokenNorm) return true;
  return buildHaystack(c).includes(tokenNorm);
}

export function getAllCommands(data: SlashCommandData): CommandRecord[] {
  const { byId, order } = data.index;
  return order.map(id => byId[id]).filter(Boolean);
}

/**
 * COMPONENT PROPS
 */
export type SlashCommandLauncherProps = {
  data: SlashCommandData;
  onSubmit: (commandId: string, args: string) => void;   // invoked on Enter/Run
  onDataChange?: (next: SlashCommandData) => void;       // propagate star/recent updates upstream
  placeholder?: string;
  defaultValue?: string;                                 // seed input (e.g., "/debug-trace id=42")
  storageKey?: string;                                   // optional: local seed/merge key for prefs
};

// Utility
const cls = (...xs: Array<string | false | undefined>) => xs.filter(Boolean).join(" ");

export default function SlashCommandLauncher({
  data,
  onSubmit,
  onDataChange,
  placeholder = "Type / to pick a command… then keep typing args",
  defaultValue = "",
  storageKey = "slashCommandPrefs",
}: SlashCommandLauncherProps) {
  const [input, setInput] = useState(defaultValue);
  const inputRef = useRef<HTMLInputElement>(null);

  // --- Seed/merge prefs from localStorage once (optional)
  useEffect(() => {
    try {
      const raw = localStorage.getItem(storageKey);
      if (!raw) return;
      const local: Partial<UserPrefs> = JSON.parse(raw);
      if (!local) return;
      // Simple merge strategy: union of starred, keep recent from data first
      const merged: SlashCommandData = {
        index: data.index,
        prefs: {
          starred: Array.from(new Set([...(data.prefs.starred || []), ...(local.starred || [])])),
          recent: data.prefs.recent && data.prefs.recent.length > 0 ? data.prefs.recent : (local.recent || []),
        },
      };
      onDataChange?.(merged);
    } catch { /* ignore */ }
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);

  // Persist prefs when they change (for seamless UX between reloads)
  useEffect(() => {
    try {
      localStorage.setItem(storageKey, JSON.stringify(data.prefs));
    } catch { /* ignore */ }
  }, [data.prefs, storageKey]);

  // --- Derived collections
  const allCommands: CommandRecord[] = useMemo(() => getAllCommands(data), [data]);

  // Parse input → {commandToken, args}
  const parsed = useMemo(() => parseInput(input), [input]);

  const tokenNorm = parsed.token.replace(/^\//, "").toLowerCase();

  // Filter by name, aliases, description, tags
  const filtered = useMemo(() => {
    const list = allCommands.filter(c => commandMatches(c, tokenNorm));
    const starredSet = new Set(data.prefs.starred);
    const byName = (a: CommandRecord, b: CommandRecord) => a.name.localeCompare(b.name);
    const starredList = list.filter(c => starredSet.has(c.id)).sort(byName);
    const rest = list.filter(c => !starredSet.has(c.id)).sort(byName);
    return { starredList, rest, all: [...starredList, ...rest] };
  }, [allCommands, data.prefs.starred, tokenNorm]);

  // Resolve the active command
  const nameOrAliasMap = useMemo(() => {
    const map = new Map<string, CommandRecord>();
    for (const c of allCommands) {
      map.set(c.name, c);
      for (const a of c.aliases || []) map.set(a, c);
    }
    return map;
  }, [allCommands]);

  const activeCommand: CommandRecord | null = useMemo(() => {
    if (parsed.token) {
      const exact = nameOrAliasMap.get(parsed.token);
      if (exact) return exact;
    }
    return filtered.all[0] ?? null;
  }, [parsed.token, nameOrAliasMap, filtered.all]);

  // Keyboard handlers: Tab → autocomplete; Enter → submit
  function handleTabAutocomplete(e: React.KeyboardEvent<HTMLInputElement>) {
    if (e.key !== "Tab") return;
    if (!parsed.token.startsWith("/")) return;
    const cand = activeCommand;
    if (!cand) return;
    e.preventDefault();
    const next = `${cand.name}${parsed.args ? ` ${parsed.args}` : " "}`;
    setInput(next);
    requestAnimationFrame(() => inputRef.current?.setSelectionRange(next.length, next.length));
  }

  function submit(cmd: CommandRecord | null) {
    if (!cmd) return;
    // update MRU
    const recent = [cmd.id, ...data.prefs.recent.filter(id => id !== cmd.id)].slice(0, 20);
    onDataChange?.({ index: data.index, prefs: { ...data.prefs, recent } });
    onSubmit(cmd.id, parsed.args);
  }

  function handleEnterToSubmit(e: React.KeyboardEvent<HTMLInputElement>) {
    if (e.key !== "Enter") return;
    if (!activeCommand) return;
    e.preventDefault();
    submit(activeCommand);
  }

  function toggleStar(cmdId: string) {
    const starred = new Set(data.prefs.starred);
    if (starred.has(cmdId)) starred.delete(cmdId); else starred.add(cmdId);
    onDataChange?.({ index: data.index, prefs: { ...data.prefs, starred: Array.from(starred) } });
  }

  function handleSelect(cmd: CommandRecord) {
    const next = `${cmd.name}${parsed.args ? ` ${parsed.args}` : " "}`;
    setInput(next);
    requestAnimationFrame(() => inputRef.current?.focus());
  }

  function clearInput() {
    setInput("");
    requestAnimationFrame(() => inputRef.current?.focus());
  }

  return (
    <div className="w-full max-w-2xl mx-auto">
      <Card className="shadow-sm border">
        <CardContent className="p-0">
          <div className="p-3">            <div className="relative">
              <Command className="rounded-lg border">
                <CommandInput
                  ref={inputRef as any}
                  value={input}
                  onValueChange={setInput}
                  onKeyDown={(e) => { handleTabAutocomplete(e); handleEnterToSubmit(e); }}
                  placeholder={placeholder}
                />
                <CommandList className="max-h-72">
                  <CommandEmpty>No commands found.</CommandEmpty>

                  {filtered.starredList.length > 0 && (
                    <CommandGroup heading="Starred">
                      {filtered.starredList.map((c) => (
                        <CommandItem
                          key={c.id}
                          value={c.name}
                          onSelect={() => handleSelect(c)}
                          className={cls("justify-between")}
                        >
                          <div className="flex flex-col">
                            <span className="font-medium">{c.name}</span>
                            <div className="flex gap-1 items-center">
                              {c.description && (
                                <span className="text-xs text-muted-foreground line-clamp-1">{c.description}</span>
                              )}
                              {(c.allowedTools || []).slice(0,3).map(t => (
                                <Badge key={t} variant="outline" className="ml-1 px-1 py-0 text-[10px]">{t}</Badge>
                              ))}
                            </div>
                          </div>
                          <Button
                            size="icon"
                            variant="ghost"
                            aria-label="Unstar"
                            onClick={(e) => { e.stopPropagation(); toggleStar(c.id); }}
                          >
                            <Star className={"h-4 w-4 fill-current text-yellow-500"}/>
                          </Button>
                        </CommandItem>
                      ))}
                    </CommandGroup>
                  )}

                  {filtered.starredList.length > 0 && filtered.rest.length > 0 && <CommandSeparator />}

                  <CommandGroup heading="Commands">
                    {filtered.rest.map((c) => (
                      <CommandItem
                        key={c.id}
                        value={c.name}
                        onSelect={() => handleSelect(c)}
                        className={cls("justify-between")}
                      >
                        <div className="flex flex-col">
                          <span className="font-medium">{c.name}</span>
                          <div className="flex gap-1 items-center">
                            {c.description && (
                              <span className="text-xs text-muted-foreground line-clamp-1">{c.description}</span>
                            )}
                            {(c.allowedTools || []).slice(0,3).map(t => (
                              <Badge key={t} variant="outline" className="ml-1 px-1 py-0 text-[10px]">{t}</Badge>
                            ))}
                          </div>
                        </div>
                        <Button
                          size="icon"
                          variant="ghost"
                          aria-label="Star"
                          onClick={(e) => { e.stopPropagation(); toggleStar(c.id); }}
                        >
                          <Star className="h-4 w-4"/>
                        </Button>
                      </CommandItem>
                    ))}
                  </CommandGroup>
                </CommandList>
              </Command>

              {/* Inline run button showing what will execute */}
              <div className="absolute right-2 top-2 flex items-center gap-2">
                {input && (
                  <Button size="icon" variant="ghost" onClick={clearInput} title="Clear">
                    <X className="h-4 w-4" />
                  </Button>
                )}
                <Button
                  variant={activeCommand ? "default" : "secondary"}
                  onClick={() => submit(activeCommand)}
                  disabled={!activeCommand}
                >
                  <CornerDownLeft className="mr-2 h-4 w-4" /> Run
                </Button>
              </div>
            </div>

            {/* Live parse preview */}
            <motion.div
              initial={{ opacity: 0, y: 4 }}
              animate={{ opacity: 1, y: 0 }}
              className="mt-3 text-xs text-muted-foreground flex items-center gap-2"
            >
              <span>Will run:</span>
              {activeCommand ? (
                <>
                  <Badge variant="secondary" className="font-mono">{activeCommand.name}</Badge>
                  {parsed.args && <span className="font-mono truncate">{parsed.args}</span>}
                </>
              ) : (
                <em className="text-muted-foreground">Pick a /command</em>
              )}
            </motion.div>
          </div>
        </CardContent>
      </Card>

      {/* Demo wiring (remove in production): */}
      <DemoHarness data={data} onSubmit={onSubmit} onDataChange={onDataChange} />
    </div>
  );
}

// --- Demo harness for the canvas preview ---
function DemoHarness({ data, onSubmit, onDataChange }: { data: SlashCommandData; onSubmit: (id:string,a:string)=>void; onDataChange?: (d:SlashCommandData)=>void }) {
  const [model, setModel] = useState<SlashCommandData>(data);
  useEffect(() => { onDataChange?.(model); }, [model, onDataChange]);

  const commands = model.index.order.map(id => model.index.byId[id]);
  const [last, setLast] = useState<{id:string;args:string}|null>(null);

  return (
    <div className="mt-4 text-sm">
      <div className="text-muted-foreground">Try: “/deb” + Tab + “ /v1/users?id=42” then Enter</div>
      <div className="mt-2 flex gap-2 flex-wrap">
        {commands.slice(0,6).map(c => (
          <Badge key={c.id} variant="outline">{c.name}</Badge>
        ))}
      </div>
      <div className="mt-3">
        {last && (
          <div className="text-muted-foreground">
            Submitted: <span className="font-mono">{last.id}</span> args <span className="font-mono">{JSON.stringify(last.args)}</span>
          </div>
        )}
      </div>
    </div>
  );
}

// Canvas demo: provide a complete model and wire onSubmit
SlashCommandLauncher.defaultProps = {
  data: {
    index: {
      byId: {
        c1: { id: "c1", name: "/debug-trace", description: "Trace FE → API → gRPC → DB and propose minimal repro", tags: ["debug","grpc","api"], allowedTools: ["Bash(*)","mcp__influx__query","Edit"], source: "project" },
        c2: { id: "c2", name: "/gen-command", description: "Scaffold a new /command from a task description", tags: ["scaffold","authoring"], allowedTools: ["Edit"], source: "project" },
        c3: { id: "c3", name: "/review", description: "Code review the staged changes", tags: ["review"], allowedTools: ["Edit"], source: "sdk" },
        c4: { id: "c4", name: "/status", description: "Summarize background tasks & model status", tags: ["status"], allowedTools: ["Bash(*)"], source: "sdk" },
        c5: { id: "c5", name: "/perf-check", description: "Run a quick perf sweep & report", tags: ["perf"], allowedTools: ["Bash(*)"], source: "project" },
        c6: { id: "c6", name: "/migrate-notes", description: "Collect notes into a doc with action items", tags: ["notes"], allowedTools: ["Edit"], source: "user" },
      },
      order: ["c1","c2","c3","c4","c5","c6"],
    },
    prefs: {
      starred: ["c1","c3"],
      recent: ["c2","c1"],
    },
  },
  onSubmit: (id: string, args: string) => {
    // In your app, run the Agent SDK with id + args. For preview just log.
    console.log("RUN:", id, args);
  }
} as Partial<SlashCommandLauncherProps>;

/**
 * UNIT TESTS (executed on module load; visible in console)
 * We keep tests simple and non-invasive so they don't disrupt UI.
 */
(function runUnitTests() {
  try {
    // parseInput tests
    console.assert(JSON.stringify(parseInput("/debug a b")) === JSON.stringify({ token: "/debug", args: "a b", raw: "/debug a b" }), "parseInput basic");
    console.assert(JSON.stringify(parseInput("   /dev/cmd x=1")) === JSON.stringify({ token: "/dev/cmd", args: "x=1", raw: "   /dev/cmd x=1" }), "parseInput trims leading");
    console.assert(JSON.stringify(parseInput("no slash")) === JSON.stringify({ token: "", args: "no slash", raw: "no slash" }), "parseInput no slash");
    console.assert(JSON.stringify(parseInput("/only")) === JSON.stringify({ token: "/only", args: "", raw: "/only" }), "parseInput only token");

    // commandMatches tests
    const sample: CommandRecord = { id: "t1", name: "/debug-trace", description: "Trace FE to DB", aliases: ["/trace"], tags: ["debug","grpc" ] };
    console.assert(commandMatches(sample, "debug"), "match by tag");
    console.assert(commandMatches(sample, "trace"), "match by alias");
    console.assert(commandMatches(sample, "fe to db"), "match by description partial");
    console.assert(!commandMatches(sample, "nonexistent"), "non-match");

    // buildHaystack newline delimiter sanity
    console.assert(buildHaystack(sample).includes("\n"), "haystack uses newline join");
    // getAllCommands order
    const dm: SlashCommandData = { index: { byId: { a: { id: "a", name: "/a" }, b: { id: "b", name: "/b" } as CommandRecord }, order: ["b","a"] }, prefs: { starred: [], recent: [] } } as any;
    const names = getAllCommands(dm).map(x => x.name).join(",");
    console.assert(names === "/b,/a", "getAllCommands keeps index.order");

    // autocomplete string format
    const args = parseInput("/debug foo=1 bar=2").args;
    const nextStr = `${sample.name}${args ? ` ${args}` : " "}`;
    console.assert(nextStr === "/debug-trace foo=1 bar=2", "autocomplete keeps args");

    console.log("[SlashCommandLauncher tests] ✅ all tests passed");
  } catch (e) {
    console.warn("[SlashCommandLauncher tests] ⚠️ tests threw", e);
  }
})();
