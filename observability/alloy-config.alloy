// Receive OTLP data from Tinstar + Claude Code containers
otelcol.receiver.otlp "default" {
  http {
    endpoint = "0.0.0.0:4318"
  }
  output {
    metrics = [otelcol.processor.transform.default.input]
  }
}

// Promote tinstar.session resource attribute to a metric-level attribute
// so it appears as a label on every Prometheus metric (not just target_info)
otelcol.processor.transform "default" {
  error_mode = "ignore"

  metric_statements {
    context    = "datapoint"
    statements = [
      "set(attributes[\"tinstar_session\"], resource.attributes[\"tinstar.session\"]) where resource.attributes[\"tinstar.session\"] != nil",
    ]
  }

  output {
    metrics = [otelcol.processor.batch.default.input]
  }
}

// Batch before exporting
otelcol.processor.batch "default" {
  output {
    metrics = [otelcol.exporter.prometheus.default.input]
  }
}

// Convert OTLP metrics to Prometheus remote-write
otelcol.exporter.prometheus "default" {
  forward_to = [prometheus.remote_write.default.receiver]
}

prometheus.remote_write "default" {
  endpoint {
    url = "http://prometheus:9090/api/v1/write"
  }
}
