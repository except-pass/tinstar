{
  "name": "tinstar",
  "version": "5.2.0-dev.0",
  "workspaces": [
    "packages/*"
  ],
  "description": "Agent orchestrator — manage multiple Claude Code sessions from a visual canvas",
  "type": "module",
  "bin": {
    "tinstar": "bin/tinstar.js"
  },
  "files": [
    "agent-skills/",
    "bin/",
    "dist/client/",
    "dist/server/",
    "README.md"
  ],
  "keywords": [
    "claude",
    "agent",
    "orchestrator",
    "ai",
    "tmux"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev:backend": "tsx watch src/server/standalone.ts --port 5281 --no-open",
    "dev:frontend": "vite",
    "dev": "concurrently --kill-others -n be,fe -c blue,green \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:observability": "docker compose -f observability/docker-compose.yml up",
    "build": "tsc -b && vite build",
    "build:server": "npx esbuild src/server/standalone.ts --bundle --platform=node --format=esm --outdir=dist/server --external:http-proxy --banner:js=\"import { createRequire } from 'node:module'; const require = createRequire(import.meta.url);\"",
    "build:all": "vite build --outDir dist/client && npm run build:server",
    "preview": "vite preview",
    "stable": "npm run build:all && node bin/tinstar.js --no-open",
    "typecheck": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.e2e.json && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint .",
    "test:unit": "vitest run --exclude='e2e/**'",
    "test:e2e": "playwright test",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "prepublishOnly": "npm run build:all"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/typography": "^0.5.19",
    "@xenova/transformers": "^2.17.2",
    "busboy": "^1.6.0",
    "fuse.js": "^7.3.0",
    "gray-matter": "^4.0.3",
    "http-proxy": "^1.18.1",
    "image-size": "^2.0.2",
    "js-yaml": "^4.1.0",
    "mermaid": "^11.14.0",
    "nats": "^2.29.3",
    "prom-client": "^15.1.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "squarify": "^1.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/busboy": "^1.5.4",
    "@types/http-proxy": "^1.17.17",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^10.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.0.5"
  }
}
