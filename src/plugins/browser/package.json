{
  "name": "browser",
  "version": "1.0.0",
  "private": true,
  "main": "src/index.tsx",
  "tinstar": {
    "apiVersion": "5",
    "displayName": "Browser widget",
    "description": "Embed web pages on the canvas",
    "contributes": {
      "widgets": [
        {
          "type": "browser-widget",
          "label": "Browser",
          "icon": "/widget-icons/browser-widget.svg",
          "defaultSize": { "width": 800, "height": 600 },
          "spawn": "palette",
          "capabilities": ["spawnable", "web-view"],
          "creator": "standalone"
        }
      ]
    },
    "permissions": []
  }
}
